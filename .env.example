# Everything below is OPTIONAL. The app runs fully without any of it
# (anonymous, local-only mode). Set these only if you want encrypted
# multi-device sync via your own free Supabase project.
#
# Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Donation links shown on the Support page (all optional)
VITE_DONATE_KOFI=
VITE_DONATE_GITHUB_SPONSORS=
VITE_DONATE_BUYMEACOFFEE=
